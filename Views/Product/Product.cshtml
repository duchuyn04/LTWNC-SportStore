@model Product
@using System.Text.Json;
@{
    Layout = "_Layout";

    var json = TempData.Peek("CategoryList")?.ToString();
    TempData.Keep("CategoryList");

    List<Category>? categories = null;
    if (!string.IsNullOrEmpty(json))
    {
        categories = JsonSerializer.Deserialize<List<Category>>(json);
    }
}

<h3 class="mb-4">Thêm sản phẩm mới</h3>

<div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

<form asp-action="Product" method="post">
    <div class="mb-3">
        <label asp-for="Name" class="form-label"></label>
        <input asp-for="Name" class="form-control" placeholder="Tên sản phẩm" />
        <span asp-validation-for="Name" class="text-danger"></span>
    </div>
    <div class="mb-3">
        <label asp-for="Description" class="form-label"></label>
        <textarea asp-for="Description" class="form-control" placeholder="Mô tả sản phẩm"></textarea>
    </div>
    <div class="mb-3">
        <label class="form-label">Danh mục:</label>
        <div class="mb-1">
            <select id="cateSelect" name="Category" class="form-control">
                <option value="">--Chọn chuyên mục--</option>
                @if (categories != null)
                {
                    @foreach (var cate in categories)
                    {
                        <option value="@cate.NameCate">@cate.NameCate</option>
                    }
                }
            </select>
        </div>
        <div>
            <input name="newCategory" class="form-control" placeholder="Hoặc nhập danh mục mới" />
        </div>
    </div>
    <div class="mb-3">
        <label asp-for="Price" class="form-label"></label>
        <input asp-for="Price" class="form-control" placeholder="Giá sản phẩm" />
        <span asp-validation-for="Price" class="text-danger"></span>
    </div>
    <div class="mb-3">
        <label asp-for="ImagePro" class="form-label"></label>
        <input asp-for="ImagePro" class="form-control" placeholder="Đường dẫn ảnh" />
    </div>
    <button type="submit" class="btn btn-primary">Lưu sản phẩm</button>
    <a asp-action="ProductList" class="btn btn-secondary">Danh sách</a>
</form>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
