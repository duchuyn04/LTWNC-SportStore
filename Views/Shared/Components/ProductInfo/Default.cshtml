@model Product
@{
    var avgRating = Model?.Reviews?.Any() == true
        ? Model.Reviews.Average(r => r.Rating)
        : 0;
    var reviewCount = Model?.Reviews?.Count ?? 0;
}

<div class="product-info">
    <span class="ss-badge ss-badge-secondary mb-2">@Model?.Category</span>
    <h1 class="page-title mb-2">@Model?.Name</h1>

    <div class="product-rating mb-3">
        @for (int i = 1; i <= 5; i++)
        {
            if (i <= Math.Round(avgRating))
            {
                <span class="star filled">★</span>
            }
            else
            {
                <span class="star">★</span>
            }
        }
        <span class="rating-text">@avgRating.ToString("0.0") (@reviewCount đánh giá)</span>
    </div>

    <p class="text-muted">@Model?.Description</p>

    <div class="product-detail-price">
        @Model?.Price.ToString("N0") đ
    </div>

    <form asp-controller="Cart" asp-action="AddToCart" method="post" class="product-actions" style="max-width: 320px;">
        <input type="hidden" name="productId" value="@Model?.ProductID" />
        <input type="hidden" name="returnUrl" value="@(Context.Request.Path + Context.Request.QueryString)" />
        <input type="number" name="quantity" value="1" min="1" class="form-control" aria-label="Số lượng" />
        <button type="submit" class="btn btn-primary btn-lg">
            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" class="me-2">
                <circle cx="9" cy="21" r="1"></circle>
                <circle cx="20" cy="21" r="1"></circle>
                <path d="M1 1h4l2.68 13.39a2 2 0 0 0 2 1.61h9.72a2 2 0 0 0 2-1.61L23 6H6"></path>
            </svg>
            Thêm vào giỏ
        </button>
    </form>

    <div>
        <a class="btn btn-outline-secondary" asp-controller="Home" asp-action="Products">
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" class="me-1">
                <path d="M19 12H5M12 19l-7-7 7-7"></path>
            </svg>
            Quay lại danh sách
        </a>
    </div>
</div>
