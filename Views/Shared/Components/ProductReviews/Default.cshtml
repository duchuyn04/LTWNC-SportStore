@model SportsStore.Models.ViewModels.ProductReviewsViewModel

<div class="product-detail-section">
    <h2 class="page-title-sm">Đánh giá sản phẩm</h2>

    <div class="row g-4">
        <div class="col-md-4">
            <div class="rating-summary">
                <div class="rating-big">@Model.AverageRating.ToString("0.0")</div>
                <div class="product-rating mb-2">
                    @for (int i = 1; i <= 5; i++)
                    {
                        <span class="star @(i <= Math.Round(Model.AverageRating) ? "filled" : "")">★</span>
                    }
                </div>
                <p class="text-muted mb-0">Dựa trên @Model.ReviewCount đánh giá</p>
            </div>
        </div>
        <div class="col-md-8">
            @if (Model.IsAuthenticated)
            {
                <form asp-controller="Home" asp-action="AddReview" method="post" class="review-form mb-4">
                    <input type="hidden" name="productId" value="@Model.ProductId" />
                    <div class="mb-3">
                        <label class="form-label">Đánh giá của bạn</label>
                        <select name="Rating" class="form-select" required>
                            <option value="">Chọn số sao</option>
                            <option value="5">5 sao - Tuyệt vời</option>
                            <option value="4">4 sao - Tốt</option>
                            <option value="3">3 sao - Bình thường</option>
                            <option value="2">2 sao - Tệ</option>
                            <option value="1">1 sao - Rất tệ</option>
                        </select>
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Nội dung</label>
                        <textarea name="Comment" class="form-control" rows="3" maxlength="1000" required
                                  placeholder="Chia sẻ trải nghiệm của bạn..."></textarea>
                    </div>
                    <button type="submit" class="btn btn-primary">Gửi đánh giá</button>
                </form>
            }
            else
            {
                <div class="ss-alert ss-alert-info mb-4">
                    <a asp-controller="Account" asp-action="Login" class="fw-bold">Đăng nhập</a> để gửi đánh giá.
                </div>
            }

            @if (Model.Reviews.Any())
            {
                <div class="review-list">
                    @foreach (var review in Model.Reviews)
                    {
                        <div class="review-item">
                            <div class="review-header">
                                <span class="review-author fw-bold">@review.UserName</span>
                                <span class="review-date text-muted">@review.CreatedAt.ToString("dd/MM/yyyy HH:mm")</span>
                            </div>
                            <div class="product-rating mb-1">
                                @for (int i = 1; i <= 5; i++)
                                {
                                    <span class="star @(i <= review.Rating ? "filled" : "")">★</span>
                                }
                            </div>
                            <p class="mb-0">@review.Comment</p>
                        </div>
                    }
                </div>
            }
            else
            {
                <p class="text-muted">Chưa có đánh giá nào. Hãy là người đầu tiên đánh giá sản phẩm này.</p>
            }
        </div>
    </div>
</div>
