<!DOCTYPE html>
<html>
<head>
    <meta name="viewport" content="width=device-width" />
    <title>FitViet</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Be+Vietnam+Pro:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.1.3/dist/css/bootstrap.min.css" rel="stylesheet"
          integrity="sha384-1BmE4kWBq78iYhFldvKuhfTAU6auU8tT94WrHftjDbrCEXSU1oBoqyl2QvZ6jIW3" crossorigin="anonymous">
    <link href="~/css/site.css" rel="stylesheet" asp-append-version="true" />
</head>
<body>
    <header class="brand-header">
        <div class="container h-100">
            <div class="d-flex justify-content-between align-items-center h-100">
                <a asp-controller="Home" asp-action="Index" class="navbar-brand">
                    FitViet
                    <span class="brand-dot" aria-hidden="true"></span>
                </a>
                <div class="header-actions">
                    @await Component.InvokeAsync("CartSummary")
                    @if (User.Identity?.IsAuthenticated == true)
                    {
                        <span class="d-none d-sm-inline text-muted small">Xin chào, <strong class="text-dark">@User.Identity.Name</strong></span>
                        <a asp-controller="Account" asp-action="Logout" class="btn btn-sm btn-outline-secondary">Đăng xuất</a>
                    }
                    else
                    {
                        <a asp-controller="Account" asp-action="Register" class="btn btn-sm btn-outline-secondary d-none d-sm-inline-block">Đăng ký</a>
                        <a asp-controller="Account" asp-action="Login" class="btn btn-sm btn-primary">Đăng nhập</a>
                    }
                </div>
            </div>
        </div>
    </header>

    <div class="page-wrap">
        <div class="main-row">
            <aside class="sidebar-col">
                <div class="sidebar-card gsap-reveal">
                    <div class="card-header">Menu</div>
                    <div class="list-group list-group-flush">
                        <a asp-controller="Home" asp-action="Products" class="list-group-item list-group-item-action">Tất cả sản phẩm</a>
                        @if (User.Identity?.IsAuthenticated == true)
                        {
                            <a asp-controller="Order" asp-action="List" class="list-group-item list-group-item-action">Đơn hàng của tôi</a>
                            @if (User.IsInRole("Admin"))
                            {
                                <a asp-area="Admin" asp-controller="Admin" asp-action="Index" class="list-group-item list-group-item-action">Quản trị sản phẩm</a>
                                <a asp-area="Admin" asp-controller="Admin" asp-action="Orders" class="list-group-item list-group-item-action">Quản trị đơn hàng</a>
                                <a asp-controller="Product" asp-action="ProductList" class="list-group-item list-group-item-action">Danh sách SP (Lab3)</a>
                                <a asp-controller="Product" asp-action="Product" class="list-group-item list-group-item-action">Thêm SP (Lab3)</a>
                            }
                            <a asp-controller="Account" asp-action="Logout" class="list-group-item list-group-item-action d-lg-none">Đăng xuất</a>
                        }
                        else
                        {
                            <a asp-controller="Account" asp-action="Register" class="list-group-item list-group-item-action d-lg-none">Đăng ký</a>
                            <a asp-controller="Account" asp-action="Login" class="list-group-item list-group-item-action d-lg-none">Đăng nhập</a>
                        }
                    </div>
                </div>
            </aside>
            <main class="page-content">
                @RenderBody()
            </main>
        </div>
    </div>

    <footer class="page-footer">
        <div class="container">
            &copy; 2026 FitViet &mdash; Thể thao trong tầm tay
        </div>
    </footer>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.1.3/dist/js/bootstrap.bundle.min.js"
            integrity="sha384-ka7Sk0Gln4gmtz2MlQnikT1wXgYsOg+OMhuP+IlRH9sENBO0LRn5q+8nbTov4+1p"
            crossorigin="anonymous"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.2/gsap.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.2/ScrollTrigger.min.js"></script>
    <script src="~/js/gsap-animations.js" asp-append-version="true"></script>
    <script src="~/js/product-gallery.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
