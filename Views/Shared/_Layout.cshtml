<!DOCTYPE html>
<html>
<head>
    <meta name="viewport" content="width=device-width" />
    <title>SportsStore</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.1.3/dist/css/bootstrap.min.css" rel="stylesheet"
          integrity="sha384-1BmE4kWBq78iYhFldvKuhfTAU6auU8tT94WrHftjDbrCEXSU1oBoqyl2QvZ6jIW3" crossorigin="anonymous">
    <link href="~/css/site.css" rel="stylesheet" />
</head>
<body>
    <header class="brand-header">
        <div class="container">
            <div class="d-flex justify-content-between align-items-center">
                <span class="navbar-brand text-white">SPORTS STORE</span>
                <div>
                    @await Component.InvokeAsync("CartSummary")
                    @if (User.Identity?.IsAuthenticated == true)
                    {
                        <span class="text-white-50 me-2">Xin chào, <strong class="text-white">@User.Identity.Name</strong></span>
                        <a asp-controller="Account" asp-action="Logout" class="btn btn-sm btn-outline-light">Đăng xuất</a>
                    }
                    else
                    {
                        <a asp-controller="Account" asp-action="Register" class="btn btn-sm btn-outline-light me-1">Đăng ký</a>
                        <a asp-controller="Account" asp-action="Login" class="btn btn-sm btn-outline-light">Đăng nhập</a>
                    }
                </div>
            </div>
        </div>
    </header>

    <div class="container my-4">
        <div class="row g-4">
            <aside class="col-3">
                <div class="sidebar-card">
                    <div class="card-header">Chức năng</div>
                    <div class="list-group list-group-flush">
                        <a asp-controller="Home" asp-action="Index" class="list-group-item list-group-item-action">Tất cả sản phẩm</a>
                        @if (User.Identity?.IsAuthenticated == true)
                        {
                            <a asp-controller="Product" asp-action="ProductList" class="list-group-item list-group-item-action">Danh sách SP (Lab3)</a>
                            <a asp-controller="Product" asp-action="Product" class="list-group-item list-group-item-action">Thêm SP (Lab3)</a>
                            <a asp-controller="Account" asp-action="Logout" class="list-group-item list-group-item-action">Đăng xuất</a>
                        }
                        else
                        {
                            <a asp-controller="Account" asp-action="Register" class="list-group-item list-group-item-action">Đăng ký</a>
                            <a asp-controller="Account" asp-action="Login" class="list-group-item list-group-item-action">Đăng nhập</a>
                        }
                    </div>
                </div>
            </aside>
            <main class="col-9 content-area">
                @RenderBody()
            </main>
        </div>
    </div>

    <footer class="page-footer">
        <div class="container">
            &copy; 2026 SPORTS STORE &mdash; Lập Trình Web Nâng Cao
        </div>
    </footer>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
