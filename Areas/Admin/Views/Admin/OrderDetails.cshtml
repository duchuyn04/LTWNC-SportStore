@model Order
@{
    Layout = "_LayoutAdmin";
}

<h1 class="page-title gsap-reveal">Chi tiết đơn hàng #@Model.OrderID</h1>

<div class="ss-order-card gsap-reveal">
    <div class="order-header">
        <span class="fw-bold">Đơn hàng #@Model.OrderID</span>
        <span class="text-muted small">@Model.OrderedAt.ToLocalTime().ToString("g")</span>
    </div>
    <div class="order-body">
        <div class="row g-3 mb-3">
            <div class="col-md-3">
                <div class="text-muted small">User ID</div>
                <div class="fw-semibold">@Model.UserId</div>
            </div>
            <div class="col-md-3">
                <div class="text-muted small">NgườI nhận</div>
                <div class="fw-semibold">@Model.Name</div>
            </div>
            <div class="col-md-3">
                <div class="text-muted small">Địa chỉ</div>
                <div class="fw-semibold">@Model.Address</div>
            </div>
            <div class="col-md-3">
                <div class="text-muted small">Điện thoại</div>
                <div class="fw-semibold">@Model.Phone</div>
            </div>
        </div>
        <div class="table-responsive">
            <table class="table table-sm table-bordered mb-0">
                <thead class="table-light">
                    <tr>
                        <th>Sản phẩm</th>
                        <th>Số lượng</th>
                        <th>Giá</th>
                        <th>Thành tiền</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var line in Model.Lines)
                    {
                        <tr>
                            <td>@line.Product?.Name</td>
                            <td>@line.Quantity</td>
                            <td>@line.Price.ToString("N0") đ</td>
                            <td class="fw-semibold text-accent">@((line.Quantity * line.Price).ToString("N0")) đ</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
        <div class="d-flex justify-content-end mt-3">
            <div class="text-end">
                <span class="text-muted small">Tổng cộng</span>
                <div class="fw-800 text-accent fs-5">@Model.TotalValue.ToString("N0") đ</div>
            </div>
        </div>
    </div>
</div>

<div class="mt-4 gsap-reveal">
    <a asp-action="Orders" class="btn btn-outline-secondary">
        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" class="me-1">
            <path d="M19 12H5M12 19l-7-7 7-7"></path>
        </svg>
        Quay lại danh sách đơn
    </a>
</div>
