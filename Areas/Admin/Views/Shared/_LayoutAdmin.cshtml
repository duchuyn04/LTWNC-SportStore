<!DOCTYPE html>
<html>
<head>
    <meta name="viewport" content="width=device-width" />
    <title>FitViet - Quản trị</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Be+Vietnam+Pro:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.1.3/dist/css/bootstrap.min.css" rel="stylesheet"
          integrity="sha384-1BmE4kWBq78iYhFldvKuhfTAU6auU8tT94WrHftjDbrCEXSU1oBoqyl2QvZ6jIW3" crossorigin="anonymous">
    <link href="~/css/site.css" rel="stylesheet" asp-append-version="true" />
</head>
<body>
    <header class="brand-header">
        <div class="container h-100">
            <div class="d-flex justify-content-between align-items-center h-100">
                @* Logo quay về trang chủ (ra khỏi area Admin). *@
                <a asp-area="" asp-controller="Home" asp-action="Index" class="navbar-brand">
                    FitViet
                    <span class="brand-dot" aria-hidden="true"></span>
                </a>
                <div class="header-actions">
                    <span class="d-none d-sm-inline text-muted small">Xin chào, <strong class="text-dark">@User.Identity?.Name</strong></span>
                    <a asp-area="" asp-controller="Account" asp-action="Logout" class="btn btn-sm btn-outline-secondary">Đăng xuất</a>
                </div>
            </div>
        </div>
    </header>

    <div class="page-wrap">
        <div class="main-row">
            <aside class="sidebar-col">
                <div class="sidebar-card">
                    <div class="card-header">Quản trị</div>
                    <div class="list-group list-group-flush">
                        @* Menu quản lý sản phẩm trong Admin area. *@
                        <a asp-area="Admin" asp-controller="Admin" asp-action="Index" class="list-group-item list-group-item-action">Quản lý sản phẩm</a>
                        @* Menu quản lý đơn hàng trong Admin area. *@
                        <a asp-area="Admin" asp-controller="Admin" asp-action="Orders" class="list-group-item list-group-item-action">Quản lý đơn hàng</a>
                        @* Link quay lại trang chủ cho admin. *@
                        <a asp-area="" asp-controller="Home" asp-action="Index" class="list-group-item list-group-item-action">Về trang chủ</a>
                    </div>
                </div>
            </aside>
            <main class="page-content">
                @RenderBody()
            </main>
        </div>
    </div>

    <footer class="page-footer">
        <div class="container">
            &copy; 2026 FitViet &mdash; Quản trị
        </div>
    </footer>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.1.3/dist/js/bootstrap.bundle.min.js"
            integrity="sha384-ka7Sk0Gln4gmtz2MlQnikT1wXgYsOg+OMhuP+IlRH9sENBO0LRn5q+8nbTov4+1p"
            crossorigin="anonymous"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
